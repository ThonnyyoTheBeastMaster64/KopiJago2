<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <!-- ScrollView supaya bisa di-scroll jika layar kecil -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== LOGO ===== -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Logo Kopi Jago" />

        <!-- Nama Aplikasi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="KOPI JAGO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Pesan Kopi Favoritmu!"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="20dp"/>

        <!-- ===== NAMA PELANGGAN ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nama"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nama"
            android:inputType="textPersonName"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- ===== EMAIL ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_email"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_email"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- ===== SPINNER PILIHAN MENU ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_menu"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:entries="@array/menu_kopi"/>

        <!-- ===== RADIO GROUP: HOT / ICE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tipe"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgTipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbHot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radio_hot"
                android:checked="true"
                android:layout_marginEnd="20dp"/>

            <RadioButton
                android:id="@+id/rbIce"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radio_ice"/>
        </RadioGroup>

        <!-- ===== CHECKBOX TAMBAHAN ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tambahan"
            android:textStyle="bold"
            android:textColor="#4A2C0A"
            android:layout_marginBottom="4dp"/>

        <CheckBox
            android:id="@+id/cbSugar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cb_sugar"/>

        <CheckBox
            android:id="@+id/cbExtraShot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cb_extra_shot"
            android:layout_marginBottom="20dp"/>

        <!-- ===== TOMBOL PESAN ===== -->
        <Button
            android:id="@+id/btnPesan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pesan"
            android:backgroundTint="#C8702A"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- ===== TOMBOL LOKASI (Implicit Intent) ===== -->
        <Button
            android:id="@+id/btnLokasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_lokasi"
            android:backgroundTint="#4A2C0A"
            android:textColor="#FFFFFF"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>